<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<pd:pipeline xmlns:pd="xsd://www.illumina.com/ica/cp/pipelinedefinition"
             code="kourami_hla_extraction"
             version="1.0">
   <pd:dataInputs>
       <pd:dataInput code="samplesheet" format="TSV" type="FILE" required="true" multiValue="false">
           <pd:label>Sample Sheet</pd:label>
           <pd:description>TSV file containing sample_id, cram_id, cram_index_id</pd:description>
       </pd:dataInput>
       
       <pd:dataInput code="cram_ref" format="FASTA" type="FILE" required="true" multiValue="false">
           <pd:label>CRAM Reference</pd:label>
           <pd:description>Reference genome FASTA file for CRAM decoding</pd:description>
       </pd:dataInput>
   </pd:dataInputs>
   
   <pd:steps>
       <pd:step execution="MANDATORY"
                code="kourami_hla_extraction">
           <pd:tool code="kourami_hla_extraction"/>
       </pd:step>
   </pd:steps>
   
   
</pd:pipeline>